{
	"name": "colombian-holidays",
	"version": "5.0.10",
	"description": "Colombian holidays",
	"type": "module",
	"sideEffects": false,
	"exports": {
		"./constants": {
			"types": "./dist/constants.d.ts",
			"import": "./dist/constants.js"
		},
		"./getHoliday": {
			"types": "./dist/utils/getHoliday.d.ts",
			"import": "./dist/utils/getHoliday.js"
		},
		"./getHolidaysByYear": {
			"types": "./dist/utils/getHolidaysByYear.d.ts",
			"import": "./dist/utils/getHolidaysByYear.js"
		},
		"./holidaysWithinInterval": {
			"types": "./dist/utils/holidaysWithinInterval.d.ts",
			"import": "./dist/utils/holidaysWithinInterval.js"
		},
		"./isHoliday": {
			"types": "./dist/utils/isHoliday.d.ts",
			"import": "./dist/utils/isHoliday.js"
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"format": "biome format --write",
		"lint": "biome lint --write",
		"test": "vitest run",
		"build": "tsup",
		"prepublishOnly": "biome check && npm test && npm run build"
	},
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/MauricioRobayo/colombian-holidays/issues"
	},
	"homepage": "https://github.com/MauricioRobayo/colombian-holidays",
	"author": "Mauricio Robayo <rfmajo@gmail.com> (https://www.mauriciorobayo.com)",
	"keywords": [
		"Colombian holidays",
		"Festivos en Colombia",
		"Colombia",
		"Festivos",
		"Holidays"
	],
	"devDependencies": {
		"@biomejs/biome": "2.5.1",
		"tsup": "^8.5.1",
		"typescript": "^6.0.3",
		"vitest": "^4.1.0"
	},
	"dependencies": {
		"pascua": "^3.0.8"
	},
	"files": [
		"dist/**/*"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/MauricioRobayo/colombian-holidays.git"
	}
}
